{
  "compilerOptions": {
    "target": "ESNext",
    "resolveJsonModule": true,
    "module": "CommonJS",
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@test-config": ["apps/tests/test-config"],
      "@test/*": ["packages/src/*"]
    },
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["packages/src/**/*", "apps/tests/**/*"]
}
