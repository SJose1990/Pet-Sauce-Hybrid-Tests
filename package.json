{
  "name": "hybrid-pet-sauce-automation",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test:api:live": "cross-env ENV=LIVE pnpm jest --selectProjects API-TESTS",
    "test:ui:live": "cross-env ENV=LIVE pnpm jest --selectProjects UI-TESTS",
    "test:all:live": "cross-env pnpm run test:api:live && pnpm run test:ui:live",
    "clean": "rm -rf html-report/ test-results/",
    "test:report": "npx jest --reporters='default' --reporters='jest-html-reporters'",
    "open:report": "open ./test-output/report.html",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"**/*.ts\""
  },
  "devDependencies": {
    "@playwright/test": "^1.41.0",
    "@types/jest": "^29.5.14",
    "@types/lodash": "^4.17.24",
    "@types/node": "^20.19.37",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "axios": "^1.13.6",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "form-data": "^4.0.0",
    "jest": "^29.7.0",
    "jest-html-reporters": "^3.1.7",
    "jest-playwright-preset": "^3.0.1",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3",
    "winston": "^3.11.0"
  },
  "packageManager": "pnpm@9.15.4+sha512.b2dc20e2fc72b3e18848459b37359a32064663e5627a51e4c74b2c29dd8e8e0491483c3abb40789cfd578bf362fb6ba8261b05f0387d76792ed6e23ea3b1b6a0",
  "dependencies": {
    "ajv": "^8.18.0",
    "lodash": "^4.17.23",
    "moment-timezone": "^0.6.0",
    "playwright": "^1.58.2"
  }
}
